# ==============================================================================
# Environment Variables Configuration
# ==============================================================================

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Admin Authentication (Used for Dashboard)
NEXT_PUBLIC_ADMIN_EMAIL="admin@coursepro.com"
NEXT_PUBLIC_ADMIN_PASSWORD="admin123"

# Database Configuration (Uncomment and update when connecting a real database)
# DATABASE_URL="postgresql://user:password@localhost:5432/coursepro"
# DIRECT_URL="postgresql://user:password@localhost:5432/coursepro"

# Next Auth / Secret Keys (Generate a secure string in production)
# NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
# NEXTAUTH_URL="http://localhost:3000"

# External APIs (e.g., Stripe, SendGrid, etc.)
# STRIPE_PUBLIC_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# SENDGRID_API_KEY="SG.your_api_key..."
